# VICAR Native Toolkit Configuration
# Copy this file to .envrc.local and customize for your setup
# .envrc.local is gitignored and won't be committed

# ===== Container Configuration =====
# Container name (must be unique if running multiple instances)
CONTAINER_NAME="vicar-sidecar"

# Docker image to use
CONTAINER_IMAGE="ghcr.io/nasa-ammos/tig/terrain-intelligence-generator:opensource"

# Options:
#   ghcr.io/nasa-ammos/tig/terrain-intelligence-generator:opensource  - Published image
#   custom-image:tag                                                  - Your custom image

# ===== VICAR Installation Paths (inside container) =====
# Configure based on your image layout. Defaults below match the
# published opensource image.
VICAR_INSTALL_PREFIX="/usr/local/vicar/dev"
VICAR_BIN_PATHS=(
    "/usr/local/bin"
)

# ===== Environment Variables (inside container) =====
# Set environment variables that VICAR/Mars tools need
VICAR_ENV_VARS=(
    "V2TOP=${VICAR_INSTALL_PREFIX}"
    "R2LIB=${VICAR_INSTALL_PREFIX}"
)

# For missions with calibration data, add:
# VICAR_ENV_VARS+=(
#     "VICAR_PARAM=/project/calibration/param_files"
#     "VICAR_CALIB=/project/calibration"
# )

# ===== Workspace Configuration =====
WORKSPACE_ROOT="${PWD}/workspace"

# ===== MARS Calibration (Camera Models & Flat Fields) =====
# Uncomment and set to mount mission calibration data
# This should point to a directory containing:
#   - camera_models/ (*.cahvor, *.cahvore files)
#   - flat_fields/ (*.IMG radiometric correction files)
#   - param_files/ (*.xml camera mapping files)
#
# Examples:
# MARS_CONFIG_PATH="${HOME}/.mars_calib"
# MARS_CONFIG_PATH="/opt/mars_calibration"
#
# If not set, container will start without calibration data.
# MARS tools will fail if they require camera models.

# ===== Additional Mounts (optional) =====
# Uncomment and configure to mount additional directories

# Mission data (read-only)
# MISSION_DATA_DIR="/data/missions"
# MISSION_DATA_MOUNT="/data/missions"

# Mars pointing files
# POINT_FILES_DIR="/proj/mars/def"
# POINT_FILES_MOUNT="/proj/mars/def"

# Parent directory for accessing sibling projects
# PARENT_DIR="$(dirname ${PWD})"
# PARENT_MOUNT="/projects"

# ===== Wrapper Generation =====
WRAPPER_DIR="${PWD}/.direnv/wrappers"

# Auto-discover executables (true) or use manual list (false)
AUTO_DISCOVER_TOOLS=true

# If AUTO_DISCOVER_TOOLS=false, list tools manually:
# MANUAL_TOOLS=(
#     label hist gen size list
#     marscorr marsxyz marsmap marsrad marstie
#     vic2pic pic2vic
# )

# ===== Platform-Specific =====
# Usually auto-detected, but can override if needed
# HOST_OS="$(uname -s)"  # Darwin or Linux
