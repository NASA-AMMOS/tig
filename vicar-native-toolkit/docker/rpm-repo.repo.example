# VICAR RPM Repository Configuration
# Copy this file to: vicar-native-toolkit/docker/rpm-repo.repo
# Or modify directly for your environment

[vicar-production]
name=VICAR Production RPM Repository
# Replace with your actual repository URL
baseurl=https://artifactory.jpl.nasa.gov/artifactory/vicar-rpm/el8/x86_64/
enabled=1
gpgcheck=0
# Set to 1 if your repository has GPG signing
# gpgkey=https://your-repo.example.com/RPM-GPG-KEY-vicar

# Optional: Authentication (if required by your repository)
# username=your-username
# password=your-password

# Optional: SSL/TLS settings
sslverify=1
# sslcacert=/etc/pki/tls/certs/ca-bundle.crt
# sslclientcert=/path/to/client.crt
# sslclientkey=/path/to/client.key

# Optional: Proxy settings (if required)
# proxy=http://proxy.example.com:8080
# proxy_username=proxy-user
# proxy_password=proxy-pass

# Optional: Repository priority (lower number = higher priority)
# priority=10

# Optional: Repository metadata settings
# metadata_expire=1h
# repo_gpgcheck=0

# ============================================================================
# Alternative Configuration Examples
# ============================================================================

# Example 1: Local file-based repository
# [vicar-local]
# name=VICAR Local Repository
# baseurl=file:///mnt/rpms/vicar/
# enabled=1
# gpgcheck=0

# Example 2: Multiple repositories for different versions
# [vicar-stable]
# name=VICAR Stable (Production)
# baseurl=https://repo.example.com/vicar/stable/el8/x86_64/
# enabled=1
# gpgcheck=1
# gpgkey=https://repo.example.com/RPM-GPG-KEY-vicar-stable
# priority=10
#
# [vicar-testing]
# name=VICAR Testing (Pre-release)
# baseurl=https://repo.example.com/vicar/testing/el8/x86_64/
# enabled=0
# gpgcheck=1
# gpgkey=https://repo.example.com/RPM-GPG-KEY-vicar-testing
# priority=20

# Example 3: Using authentication with environment variables
# (requires additional Docker configuration)
# [vicar-secure]
# name=VICAR Secure Repository
# baseurl=https://secure-repo.example.com/vicar/el8/x86_64/
# enabled=1
# gpgcheck=1
# username=$REPO_USERNAME
# password=$REPO_PASSWORD

# ============================================================================
# Common Repository URLs (Update with your actual values)
# ============================================================================

# JPL Artifactory (JPL network or VPN required)
# baseurl=https://artifactory.jpl.nasa.gov/artifactory/vicar-rpm/el8/x86_64/

# AWS S3 bucket
# baseurl=https://s3.amazonaws.com/your-bucket/vicar-rpm/el8/x86_64/

# HTTP server
# baseurl=http://your-server.example.com/vicar/el8/x86_64/

# NFS mount (requires mounting in container)
# baseurl=file:///mnt/nfs-share/vicar-rpm/el8/x86_64/

# ============================================================================
# Notes
# ============================================================================

# 1. Repository structure should follow standard RPM layout:
#    baseurl/
#    ├── repodata/
#    │   ├── repomd.xml
#    │   ├── primary.xml.gz
#    │   ├── filelists.xml.gz
#    │   └── other.xml.gz
#    ├── vicar-m20-g87-all-1.0.0-1.el8.x86_64.rpm
#    └── vicar-external-*.rpm

# 2. Test repository access before building:
#    curl -I https://your-repo.example.com/vicar/el8/x86_64/repodata/repomd.xml

# 3. If using local files, place RPMs in docker/rpms/ directory instead
#    and modify Dockerfile to use: dnf install /path/to/rpms/*.rpm

# 4. For private repositories, ensure Docker build has network access
#    or use Docker buildx with custom network configuration

# 5. GPG key verification (recommended for production):
#    - Enable gpgcheck=1
#    - Provide gpgkey URL
#    - Ensure RPMs are signed with matching key
